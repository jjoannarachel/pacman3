{
  "name": "pacman",
  "version": "1.0.1",
  "description": "Pacman WebVR",
  "main": "index.js",
  "scripts": {
    "start": "webpack-dev-server --mode development --open --hot",
    "build": "webpack --mode production"
  },
  "author": "Qian Sha",
  "license": "MIT",
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "babel-core": "^6.26.3",
    "babel-jest": "^29.7.0",
    "babel-loader": "^7.1.5",
    "babel-plugin-transform-runtime": "^6.23.0",
    "babel-preset-env": "^1.7.0",
    "file-loader": "^3.0.1",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.3.0",
    "webpack": "^4.21.0",
    "webpack-cli": "^3.1.2",
    "webpack-dev-server": "^3.1.9"
  },
  "dependencies": {
    "aframe": "^0.8.2",
    "aframe-extras": "^5.0.0",
    "aframe-particle-system-component": "^1.1.3",
    "fast-text-encoding": "^1.0.0",
    "howler": "^2.1.1"
  },
  "jest": {
    "collectCoverage": true,
    "collectCoverageFrom": [
      "src/**/*.js"
    ],
    "coverageReporters": [
      "text",
      "lcov"
    ],
    "testEnvironment": "node",
    "transform": {
      "^.+\\.js$": "babel-jest"
    },
    "transformIgnorePatterns": [],
    "moduleNameMapper": {
      "^aframe$": "<rootDir>/__mocks__/aframe.js",
      "^aframe-extras$": "<rootDir>/__mocks__/aframe-extras.js",
      "^aframe-particle-system-component$": "<rootDir>/__mocks__/aframe-particle-system-component.js",
      "^fast-text-encoding$": "<rootDir>/__mocks__/fast-text-encoding.js",
      "^howler$": "<rootDir>/__mocks__/howler.js"
    }
  }
}
